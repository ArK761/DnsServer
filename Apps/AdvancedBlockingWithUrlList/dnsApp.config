{
  "enableBlocking": true,
  "blockingAnswerTtl": 30,
  "blockListUrlUpdateIntervalMinutes": 5,
  "blockListUrlUpdateSleepSeconds": 30,
  "httpTimeoutSeconds": 30,

  "ipListResolveIntervalSeconds": 300,
  "ipListResolveDnsServers": [ "172.30.1.5" ],

  "ipListMaps": {
    "https://XYZ/List_1": "List1",
    "https://XYZ/List_2": "List2"
  },

  "groups": [
    {
      "name": "List1",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    },
    {
      "name": "List2",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    }
  ],
  "defaultBlock": {
    "allowTxtBlockingReport": false,
    "blockAsNxDomain": false,
    "blockingAddresses": [ "127.0.0.1" ]
  }
}
