{
  "blockingAnswerTtl": 30,
  "blockListUrlUpdateIntervalMinutes": 5,
  "blockListUrlUpdateSleepSeconds": 30,
  "httpTimeoutSeconds": 30,

  "ipListResolveIntervalSeconds": 300,
  "ipListResolveDnsServers": [ "DnsServer" ],

  "ipListMaps": {
    "https://XYZ/FqdnList_1": "List1",
    "https://XYZ/FqdnList_1": "List2"
  },
  "ipListCDIR": {
    ## ALLOW CDIR WITH NO MASK 32 ##
    ## NOT ALLOWED OR NOT RESLOVE FQDN ##
    "https://XYZ/Cder1": "Name_1",
    "https://XYZ/Cder2": "Name_2"
  },
  "groups": [
    {
      "name": "List1",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    },
    {
      "name": "List2",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    },
    {
      "name": "Name_1",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    }
  ],
  "defaultBlock": {
    "allowTxtBlockingReport": false,
    "blockAsNxDomain": false,
    "blockingAddresses": [ "127.0.0.1" ],
    "queryNameSuffixesToStrip": [ "domain.local" ]
  }
}
