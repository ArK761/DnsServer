{
  "enableBlocking": true,
  "blockingAnswerTtl": 30,
  "blockListUrlUpdateIntervalMinutes": 5,
  "blockListUrlUpdateSleepSeconds": 30,
  "httpTimeoutSeconds": 30,

  "ipListResolveIntervalSeconds": 300,
  "ipListResolveDnsServers": [ "10.0.0.1" ],

  "ipListMaps": {
    "https://XX/List_1": "List1",
    "https://XX/List_2": "List2"
  },

  "groups": [
    {
      "name": "List1",
      "enableBlocking": true,
      "allowTxtBlockingReport": false,
      "blockAsNxDomain": false,
      "blockingAddresses": [ "127.0.0.1" ],
      "allowed": [],
      "blocked": [],
      "allowListUrls": [],
      "blockListUrls": [],
      "ipListUrls": [ "List1" ],
      "allowedRegex": [],
      "regexAllowListUrls": [],
      "blockedRegex": [ "^(.*)$" ],
      "regexBlockListUrls": [],
      "adblockListUrls": []
    },
    {
      "name": "List2",
      "enableBlocking": true,
      "allowTxtBlockingReport": false,
      "blockAsNxDomain": false,
      "blockingAddresses": [ "127.0.0.1" ],
      "allowed": [],
      "blocked": [],
      "allowListUrls": [],
      "blockListUrls": [],
      "ipListUrls": [ "List2" ],
      "allowedRegex": [],
      "regexAllowListUrls": [],
      "blockedRegex": [],
      "regexBlockListUrls": [],
      "adblockListUrls": []
    }
  ]
}
