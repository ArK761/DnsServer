{
  "blockingAnswerTtl": 30,
  "blockListUrlUpdateIntervalMinutes": 5,
  "blockListUrlUpdateSleepSeconds": 30,
  "httpTimeoutSeconds": 30,

  "ipListResolveIntervalSeconds": 300,
  "ipListResolveDnsServers": [ "DnsServer" ],

  "ipListMaps": {
    "https://XYZ/FqdnList_1": "List1",
    "https://XYZ/FqdnList_2": "List2"
  },

  "ipListCIDR": {
    "https://XYZ/CidrList_1": "Name_1",
    "https://XYZ/CidrList_2": "Name_2"
  },

  "groups": [
    {
      "name": "List1",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    },
    {
      "name": "List2",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    },
    {
      "name": "Name_1",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    },
    {
      "name": "Name_2",
      "allowed": [],
      "allowListUrls": [],
      "allowedRegex": [],
      "regexAllowListUrls": []
    }
  ],

  "defaultBlock": {
    "allowTxtBlockingReport": false,
    "blockAsNxDomain": false,
    "blockingAddresses": [ "127.0.0.1" ],
    "queryNameSuffixesToStrip": [ "domain.local" ]
  }
}
